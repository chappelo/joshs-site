---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

const projects = await getCollection("projects");
---

<Layout>
  <div class="flex flex-col px-8 w-full min-h-screen">
    <div class="flex items-center py-4 xl:py-6">
      <a
        href="/"
        class="text-black hover:opacity-75 transition-opacity duration-300"
      >
        <Icon
          name="back"
          class="inline-block animate-rightslide opacity-0 w-10 h-10 md:h-24 md:w-24 duration-300"
        />
      </a>
      <h1
        class="text-5xl md:text-6xl xl:text-8xl font-kabelB animate-leftslide opacity-0"
      >
        PROJECTS
      </h1>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 py-4">
      {
        projects.map(({ data }, index) => (
          <div
            class="group block animate-rightslide opacity-0 relative"
            style={`animation-delay: ${index * 0.1}s`}
          >
            <div class="border border-black rounded-lg p-6 h-full transition-all duration-300 hover:shadow-lg bg-white">
              <a
                href={data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="absolute inset-0 rounded-lg"
                aria-label={data.title}
              />
              <h2 class="font-kabelB text-xl md:text-2xl xl:text-3xl uppercase mb-2 transition-opacity duration-300">
                {data.title}
              </h2>
              <p class="font-kabelL text-base md:text-lg text-gray-700 mb-4">
                {data.blurb}
              </p>
              {data.links && (
                <ul class="flex flex-col gap-1 mt-2 relative z-10">
                  {data.links.map((link) => (
                    <li class="font-kabelL text-sm text-gray-700">
                      {link.label}{" "}
                      {link.urls.map((url) => (
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary underline hover:opacity-75 transition-opacity duration-300 mr-1"
                        >
                          #{url.split("/").pop()} ↗
                        </a>
                      ))}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
