---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

const posts = await getCollection("posts");

posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout>
  <div class="flex flex-col px-8 w-[38rem] mx-auto">
    <div class="flex items-center py-4 xl:py-6">
      <a
        href="/"
        class="text-black hover:opacity-75 transition-opacity duration-300"
      >
        <Icon
          name="back"
          class="inline-block animate-rightslide opacity-0 w-10 h-10 md:h-24 md:w-24 duration-300"
        />
      </a>
      <h1
        class="text-5xl md:text-6xl xl:text-8xl font-kabelB animate-leftslide opacity-0"
      >
        POSTS
      </h1>
    </div>
    {
      posts.map(({ data }) => (
        <a
          href={`/post/${data.title}`}
          class="font-kabelL text-lg md:text-xl xl:text-2xl inline-block group relative w-max leading-relaxed md:leading-relaxed xl:leading-relaxed animate-rightslide opacity-0 py-4 uppercase"
        >
          {data.title}
          <p class="text-sm text-primary">{data.date}</p>
          <span class="absolute -bottom-0.5 left-0 w-0 transition-all duration-300 h-1 bg-black group-hover:w-full rounded-md" />
        </a>
      ))
    }
  </div>
</Layout>
