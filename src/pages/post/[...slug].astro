---
import Layout from "@/layouts/Layout.astro";
import { getEntry } from "astro:content";

const { slug } = Astro.params;

if (slug == undefined) {
  throw new Error("No slug found.");
}

const entry = await getEntry("posts", slug);

if (entry == undefined) {
  return Astro.redirect("/404");
}

const { Content } = await entry.render();
---

<Layout>
  <div class="flex justify-center mx-auto">
    <div
      class="flex flex-col px-8 w-full md:w-3/4 xl:w-1/2 xl:min-w-[800px] py-16 h-full"
    >
      <h1 class="text-5xl uppercase animate-leftslide opacity-0 font-kabelB">
        {entry.data.title}
      </h1>
      <div
        class="animate-rightslide opacity-0 [&>p]:my-7 [&>p]:leading-relaxed [&>p]:xl:text-lg [&>p]:md:text-base [&>p]:text-sm [&>p]:font-kabelL"
      >
        <Content />
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  img {
    margin-inline: auto;
  }
</style>
