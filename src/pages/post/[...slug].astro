---
import Layout from "@/layouts/Layout.astro";
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

const { slug } = Astro.params;

if (slug == undefined) {
  throw new Error("No slug found.");
}

const entry = await getEntry("posts", slug);

if (entry == undefined) {
  return Astro.redirect("/404");
}

const { Content } = await entry.render();
---

<Layout>
  <div class="flex justify-center mx-auto">
    <div
      class="flex flex-col px-8 w-full md:w-3/4 xl:w-1/2 xl:min-w-[800px] py-16 h-full"
    >
      <div class="flex items-center">
        <a
          href="/posts"
          class="text-black hover:opacity-75 transition-opacity duration-300"
        >
          <Icon
            name="back"
            class="inline-block animate-rightslide opacity-0 w-10 h-10 md:h-16 md:w-16 duration-300"
          />
        </a>
        <h1 class="text-5xl uppercase animate-leftslide opacity-0 font-kabelB">
          {entry.data.title}
        </h1>
      </div>
      <div
        class="animate-rightslide opacity-0 [&>p]:my-7 [&>p]:leading-relaxed [&>p]:xl:text-lg [&>p]:md:text-base [&>p]:text-sm [&>p]:font-kabelL"
        style="background-color: white; border-radius: 1rem; padding: 1rem; box-shadow: 0 4px 8px #0000000f, 0 6px 12px #0000000f;"
      >
        <Content />
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  img {
    margin-inline: auto;
  }
</style>
